        "button_link": "/pages/locate-us",
        "button_style": "secondary",
        "text_alignment": "left",
        "background_color": "#ffffff",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },

    "newsletter": {
      "type": "email-signup",
      "settings": {
        "heading": "Be the First to Know",
        "subheading": "Subscribe for new collection launches, exclusive offers, and home inspiration.",
        "placeholder": "Enter your email address",
        "button_label": "Subscribe",
        "background_style": "accent",
        "background_color": "#1a1a1a",
        "text_color": "#ffffff",
        "padding_top": 64,
        "padding_bottom": 64
      }
    }
